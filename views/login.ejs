<%- include('partials/head', { title: 'Log in' }) %>
<%- include('partials/nav') %>

<main>
  <div class="auth-page">
    <%- include('partials/flash') %>
    <div class="auth-card">
      <h2>Welcome back</h2>
      <p class="auth-sub">Log in to access your career assessment and results.</p>

      <form action="/auth/login" method="POST" id="loginForm" novalidate>
        <div class="field">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required>
          <span class="field-err" id="emailErr">Please enter a valid email.</span>
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="Your password" required>
          <span class="field-err" id="pwdErr">Please enter your password.</span>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Log in</button>
      </form>

      <p class="auth-switch">Don't have an account? <a href="/auth/register">Register here</a></p>
    </div>
  </div>
</main>

<%- include('partials/foot') %>
